Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(app|config|database|storage/logs|vendor)(/|$) - [F,L]
    RewriteRule ^assets/(.+)$ public/assets/$1 [L]
    RewriteRule ^favicon\.ico$ public/favicon.ico [L]
    RewriteRule ^$ public/index.php [E=APP_REQUEST_PATH:/,L]
    RewriteRule ^(.+)$ public/index.php [E=APP_REQUEST_PATH:/$1,L]
</IfModule>
