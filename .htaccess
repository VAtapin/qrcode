Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(app|config|database|storage/logs|vendor)(/|$) - [F,END]
    RewriteRule ^assets/(.+)$ public/assets/$1 [END]
    RewriteRule ^favicon\.ico$ public/favicon.ico [END]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [END]

    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -d
    RewriteRule ^(.+)$ public/$1 [END]

    RewriteRule ^$ public/index.php [E=APP_REQUEST_PATH:/,END]
    RewriteRule ^(.+)$ public/index.php [E=APP_REQUEST_PATH:/$1,END]
</IfModule>
